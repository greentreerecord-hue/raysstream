generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  comments Comment[]
}

model Comment {
  id       String @id @default(cuid())
  content  String
  videoId  String
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
} 