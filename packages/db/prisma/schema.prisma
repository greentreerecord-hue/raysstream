generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  VIEWER
  CREATOR
  ADMIN
}

enum VideoStatus {
  DRAFT
  PROCESSING
  READY
  PUBLISHED
  FAILED
  ARCHIVED
}

enum Visibility {
  PUBLIC
  PREMIUM
  PRIVATE
}

enum SubscriptionPlan {
  MOBILE
  STANDARD
  PREMIUM
}

model User {
  id              String                @id @default(cuid())
  email           String                @unique
  passwordHash    String
  name            String
  avatarUrl       String?
  role            UserRole              @default(VIEWER)
  plan            SubscriptionPlan      @default(MOBILE)
  payoutAccountId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  channel         Channel?
  sessions        Session[]
  comments        Comment[]
  likes           VideoLike[]
  watchlist       WatchlistItem[]
  watchHistory    WatchHistory[]
  creatorFollows  CreatorSubscription[] @relation("Follower")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Channel {
  id           String                @id @default(cuid())
  ownerId      String                @unique
  name         String                @unique
  slug         String                @unique
  description  String?
  bannerUrl    String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  owner        User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  videos       Video[]
  subscribers  CreatorSubscription[]
}

model Video {
  id              String          @id @default(cuid())
  channelId       String
  title           String
  slug            String          @unique
  description     String?
  category        String
  type            String
  year            Int?
  durationSeconds Int?
  thumbnailUrl    String?
  trailerUrl      String?
  sourceUrl       String?
  playbackUrl     String?
  manifestUrl     String?
  status          VideoStatus     @default(DRAFT)
  visibility      Visibility      @default(PUBLIC)
  premium         Boolean         @default(false)
  monetized       Boolean         @default(true)
  viewsCount      Int             @default(0)
  likesCount      Int             @default(0)
  commentsCount   Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  publishedAt     DateTime?
  channel         Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  comments        Comment[]
  likes           VideoLike[]
  watchlistedBy   WatchlistItem[]
  watchHistory    WatchHistory[]
}

model Comment {
  id         String   @id @default(cuid())
  videoId    String
  authorId   String
  body       String
  likesCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model VideoLike {
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
}

model WatchlistItem {
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
}

model WatchHistory {
  id              String   @id @default(cuid())
  userId          String
  videoId         String
  progressSeconds Int      @default(0)
  completed       Boolean  @default(false)
  lastWatchedAt   DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video           Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model CreatorSubscription {
  followerId String
  channelId  String
  createdAt  DateTime @default(now())
  follower   User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([followerId, channelId])
}

model PaymentCustomer {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String   @unique
  stripeSubscriptionId String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
